{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default (x86_64, Debug, Ninja)",
            "description": "Default debug build for x86_64 using Ninja. i386 is hard deprecated.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "x86_64"
            }
        },
        {
            "name": "x86_64-release",
            "displayName": "x86_64 Release",
            "description": "Optimized release build for x86_64",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-x86_64-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "x86_64"
            }
        },
        {
            "name": "x86_64-debug",
            "displayName": "x86_64 Debug",
            "description": "Debug build for x86_64",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-x86_64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "x86_64"
            }
        },
        {
            "name": "i386-debug",
            "displayName": "i386 Debug (PHASE 3 HARD DEPRECATED)",
            "description": "Debug build for i386 (Phase 3 hard deprecated — requires MKI386=ON)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-i386-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "i386",
                "MKI386": "ON"
            }
        },
        {
            "name": "i386-release",
            "displayName": "i386 Release (PHASE 3 HARD DEPRECATED)",
            "description": "Release build for i386 (Phase 3 hard deprecated — requires MKI386=ON)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-i386-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "i386",
                "MKI386": "ON"
            }
        },
        {
            "name": "i386-minimal",
            "displayName": "i386 Minimal (PHASE 3 HARD DEPRECATED)",
            "description": "Minimal build (MKIMAGEONLY) for i386 (Phase 3 hard deprecated)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-i386-minimal",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "i386",
                "MKI386": "ON",
                "MKIMAGEONLY": "ON",
                "MKSMALL": "ON"
            }
        },
        {
            "name": "i386-coverage",
            "displayName": "i386 Coverage (PHASE 3 HARD DEPRECATED)",
            "description": "Coverage build for i386 (Phase 3 hard deprecated)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-i386-cov",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "i386",
                "MKI386": "ON",
                "MKCOVERAGE": "ON"
            }
        },
        {
            "name": "earm-debug",
            "displayName": "ARM Debug",
            "description": "Debug build for ARM (earm)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-earm",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchain-minix.cmake",
                "MACHINE_ARCH": "earm"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default"
        },
        {
            "name": "x86_64-release",
            "configurePreset": "x86_64-release"
        },
        {
            "name": "i386-debug",
            "configurePreset": "i386-debug"
        },
        {
            "name": "i386-release",
            "configurePreset": "i386-release"
        },
        {
            "name": "earm-debug",
            "configurePreset": "earm-debug"
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
